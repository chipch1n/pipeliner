# Copy to .env and fill in values ( .env is gitignored )

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pipeliner
DB_USER=postgres
DB_PASSWORD=postgres

# Required for auth (change in production)
FIXED_SALT=dev-change-me

# Hugging Face — hf_image_to_image node
# Fine-grained token with "Make calls to Inference Providers":
# https://huggingface.co/settings/tokens
HF_TOKEN=

# Optional alias for HF_TOKEN
# HUGGINGFACE_HUB_TOKEN=

# SMTP lockout alerts
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
LOCKOUT_ALERT_EMAIL=admin@example.com
